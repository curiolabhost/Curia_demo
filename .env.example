# Copy to .env (or .env.local) and fill in real values. Both files are gitignored.

# PostgreSQL connection (Neon in production / hosted dev).
DATABASE_URL="postgresql://..."

# Optional: unpooled Postgres URL, used by Prisma's directUrl for migrations.
# Required when DATABASE_URL points at a pgbouncer-pooled endpoint (e.g. Neon).
DATABASE_URL_UNPOOLED="postgresql://..."

# JWT signing key for the session cookie (lib/session.ts).
# Generate a cryptographically random 32+ char string for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET="generate-a-random-32-char-string"
