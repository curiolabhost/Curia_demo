# Copy to .env (or .env.local) and fill in real values. Both files are gitignored.

# PostgreSQL connection (Neon in production / hosted dev).
DATABASE_URL="postgresql://..."

# Optional: unpooled Postgres URL, used by Prisma's directUrl for migrations.
# Required when DATABASE_URL points at a pgbouncer-pooled endpoint (e.g. Neon).
DATABASE_URL_UNPOOLED="postgresql://..."

# JWT signing key for the session cookie (lib/session.ts).
# Generate a cryptographically random 32+ char string for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET="generate-a-random-32-char-string"

# Transactional email for classroom invites (lib/email.ts), sent via Resend.
# RESEND_API_KEY: from https://resend.com/api-keys
# EMAIL_FROM: a verified sender on your Resend domain. Until a domain is verified,
#   Resend only delivers to your own account address and you can use onboarding@resend.dev.
# APP_URL: public base URL used to build invite links (no trailing slash).
#   On Vercel this is auto-detected from VERCEL_PROJECT_PRODUCTION_URL, so you
#   only need APP_URL for local dev or to force a specific domain.
# To email recipients OTHER than your own Resend account address, verify a
#   domain at https://resend.com/domains and set EMAIL_FROM to it
#   (e.g. "Curia <invites@acuriolab.org>"). The default onboarding@resend.dev
#   sender only delivers to your own account email.
RESEND_API_KEY=""
EMAIL_FROM="Curia <onboarding@resend.dev>"
APP_URL="http://localhost:3000"
