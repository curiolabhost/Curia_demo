generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  STUDENT
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  username     String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentMemberships StudentMembership[]
  adminMemberships   AdminMembership[]
}

model Classroom {
  id          String   @id @default(cuid())
  name        String
  description String?
  subject     String?
  joinCode    String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentMemberships StudentMembership[]
  adminMemberships   AdminMembership[]
  slidesDecks        SlidesDeck[]
  liveSessions       LiveSession[]
}

model StudentMembership {
  id           String    @id @default(cuid())
  userId       String?
  classroomId  String
  studentKey   String
  firstName    String?
  lastName     String?
  lastLessonId String?
  joinedAt     DateTime?

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  lessonProgress       LessonProgress[]
  exerciseProgress     ExerciseProgress[]
  finalProjectProgress FinalProjectProgress[]
  codeEditorState      CodeEditorState[]
  liveResponses        LiveResponse[]
  liveParticipants     LiveParticipant[]

  @@unique([userId, classroomId])
  @@unique([classroomId, studentKey])
}

model AdminMembership {
  id          String    @id @default(cuid())
  userId      String?
  classroomId String
  adminKey    String
  isOwner     Boolean   @default(false)
  joinedAt    DateTime?

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  liveSessions LiveSession[]

  adminLessonProgress       AdminLessonProgress[]
  adminExerciseProgress     AdminExerciseProgress[]
  adminCodeEditorState      AdminCodeEditorState[]
  adminFinalProjectProgress AdminFinalProjectProgress[]

  @@unique([userId, classroomId])
  @@unique([classroomId, adminKey])
}

model LessonProgress {
  id                 String    @id @default(cuid())
  membershipId       String
  lessonId           String
  lastExerciseIndex  Int       @default(0)
  lastChallengeIndex Int       @default(0)
  lastMode           String    @default("exercises")
  completedAt        DateTime?
  updatedAt          DateTime  @updatedAt

  membership StudentMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, lessonId])
}

model ExerciseProgress {
  id            String    @id @default(cuid())
  membershipId  String
  lessonId      String
  exerciseIndex Int
  format        String
  answerState   Json
  completed     Boolean   @default(false)
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  membership StudentMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, lessonId, exerciseIndex])
}

model FinalProjectProgress {
  id               String    @id @default(cuid())
  membershipId     String
  lessonId         String
  activeBlockIndex Int       @default(0)
  blocks           Json      @default("{}")
  editedHtml       String?   @db.Text
  editedCss        String?   @db.Text
  completedAt      DateTime?
  updatedAt        DateTime  @updatedAt

  membership StudentMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, lessonId])
}

model CodeEditorState {
  id            String    @id @default(cuid())
  membershipId  String
  lessonId      String
  exerciseIndex Int
  code          String    @db.Text
  completed     Boolean   @default(false)
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  membership StudentMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, lessonId, exerciseIndex])
}

model AdminLessonProgress {
  id                String    @id @default(cuid())
  adminMembershipId String
  lessonId          String
  lastExerciseIndex  Int       @default(0)
  lastChallengeIndex Int       @default(0)
  lastMode          String    @default("exercises")
  completedAt       DateTime?
  updatedAt         DateTime  @updatedAt

  adminMembership AdminMembership @relation(fields: [adminMembershipId], references: [id], onDelete: Cascade)

  @@unique([adminMembershipId, lessonId])
}

model AdminExerciseProgress {
  id                String    @id @default(cuid())
  adminMembershipId String
  lessonId          String
  exerciseIndex     Int
  format            String
  answerState       Json
  completed         Boolean   @default(false)
  completedAt       DateTime?
  updatedAt         DateTime  @updatedAt

  adminMembership AdminMembership @relation(fields: [adminMembershipId], references: [id], onDelete: Cascade)

  @@unique([adminMembershipId, lessonId, exerciseIndex])
}

model AdminCodeEditorState {
  id                String    @id @default(cuid())
  adminMembershipId String
  lessonId          String
  exerciseIndex     Int
  code              String    @db.Text
  completed         Boolean   @default(false)
  completedAt       DateTime?
  updatedAt         DateTime  @updatedAt

  adminMembership AdminMembership @relation(fields: [adminMembershipId], references: [id], onDelete: Cascade)

  @@unique([adminMembershipId, lessonId, exerciseIndex])
}

model AdminFinalProjectProgress {
  id                String    @id @default(cuid())
  adminMembershipId String
  lessonId          String
  activeBlockIndex  Int       @default(0)
  blocks            Json      @default("{}")
  editedHtml        String?   @db.Text
  editedCss         String?   @db.Text
  completedAt       DateTime?
  updatedAt         DateTime  @updatedAt

  adminMembership AdminMembership @relation(fields: [adminMembershipId], references: [id], onDelete: Cascade)

  @@unique([adminMembershipId, lessonId])
}

model SlidesDeck {
  id                 String   @id @default(cuid())
  classroomId        String
  lessonId           String
  lastEditedByUserId String?
  slides             Json
  updatedAt          DateTime @updatedAt

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([classroomId, lessonId])
}

model LiveSession {
  id                     String    @id @default(cuid())
  classroomId            String
  instructorMembershipId String
  lessonId               String
  currentSlideType       String?
  currentSlideIndex      Int?
  currentExerciseIndex   Int?
  pollOpen               Boolean   @default(false)
  phase                  String    @default("idle")
  pollEndsAt             DateTime?
  pollDurationSeconds    Int?
  status                 String    @default("active")
  startedAt              DateTime  @default(now())
  endedAt                DateTime?

  classroom            Classroom       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  instructorMembership AdminMembership @relation(fields: [instructorMembershipId], references: [id], onDelete: Cascade)

  responses    LiveResponse[]
  participants LiveParticipant[]
}

model LiveParticipant {
  id            String   @id @default(cuid())
  liveSessionId String
  membershipId  String
  joinedAt      DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  liveSession LiveSession       @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  membership  StudentMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, membershipId])
}

model LiveResponse {
  id            String   @id @default(cuid())
  liveSessionId String
  membershipId  String
  lessonId      String
  exerciseIndex Int
  isCorrect     Boolean
  answer        Json?
  score         Int      @default(0)
  submittedAt   DateTime @default(now())

  liveSession LiveSession       @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  membership  StudentMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, membershipId, exerciseIndex])
}